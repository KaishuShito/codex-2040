      "checkConstraints": {
        "game_runs_language_check": {
          "name": "game_runs_language_check",
          "value": "\"game_runs\".\"language\" IN ('ja', 'en')"
        },
        "game_runs_final_score_check": {
          "name": "game_runs_final_score_check",
          "value": "\"game_runs\".\"final_score\" IS NULL OR \"game_runs\".\"final_score\" BETWEEN 0 AND 100"
        },
        "game_runs_rank_check": {
          "name": "game_runs_rank_check",
          "value": "\"game_runs\".\"rank\" IS NULL OR \"game_runs\".\"rank\" IN ('S', 'A', 'B', 'C')"
        },
        "game_runs_ending_check": {
          "name": "game_runs_ending_check",
          "value": "\"game_runs\".\"ending\" IS NULL OR \"game_runs\".\"ending\" IN ('beneficial-abundance', 'managed-transition', 'fragile-abundance', 'race-future', 'regulatory-freeze', 'safety-incident', 'misalignment', 'pyrrhic-monopoly')"
        },
        "game_runs_choice_2029_check": {
          "name": "game_runs_choice_2029_check",
          "value": "\"game_runs\".\"choice_2029\" IS NULL OR \"game_runs\".\"choice_2029\" IN ('race', 'slowdown', 'verified-slowdown')"
        },
        "game_runs_choice_2035_check": {
          "name": "game_runs_choice_2035_check",
          "value": "\"game_runs\".\"choice_2035\" IS NULL OR \"game_runs\".\"choice_2035\" IN ('hold-the-line', 'accelerate')"
        },
        "game_runs_active_play_seconds_check": {
          "name": "game_runs_active_play_seconds_check",
          "value": "\"game_runs\".\"active_play_seconds\" IS NULL OR \"game_runs\".\"active_play_seconds\" BETWEEN 0 AND 21600"
        },
        "game_runs_completion_check": {
          "name": "game_runs_completion_check",
          "value": "(\"game_runs\".\"completed_at\" IS NULL AND \"game_runs\".\"final_score\" IS NULL AND \"game_runs\".\"rank\" IS NULL AND \"game_runs\".\"ending\" IS NULL AND \"game_runs\".\"active_play_seconds\" IS NULL) OR (\"game_runs\".\"completed_at\" IS NOT NULL AND \"game_runs\".\"final_score\" IS NOT NULL AND \"game_runs\".\"rank\" IS NOT NULL AND \"game_runs\".\"ending\" IS NOT NULL AND \"game_runs\".\"active_play_seconds\" IS NOT NULL)"
        }
      }
